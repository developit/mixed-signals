{
  "name": "mixed-signals",
  "version": "0.2.1",
  "description": "RPC Reflection for Preact Models & Signals: use Models/Signals from a somewhere else (server/worker/etc) as if they were here.",
  "type": "module",
  "exports": {
    "./server": {
      "types": "./build/server.d.ts",
      "default": "./build/server.js"
    },
    "./client": {
      "types": "./build/client.d.ts",
      "default": "./build/client.js"
    },
    "./disposable.d.ts": "./disposable.d.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "build",
    "server",
    "client",
    "shared"
  ],
  "scripts": {
    "test": "vitest",
    "build": "tsdown",
    "typecheck": "tsc",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "docs:api": "node scripts/generate-readme.mjs",
    "prepublishOnly": "tsdown && node scripts/generate-readme.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "bench": "tsx bench/index.ts --mode=inproc --profile=dev",
    "bench:workers": "tsx bench/index.ts --mode=workers --profile=dev",
    "bench:full": "tsx bench/index.ts --mode=inproc --profile=full",
    "bench:d8": "node bench/scripts/run-d8.mjs --profile=full",
    "bench:d8:debug": "node bench/scripts/run-d8.mjs --debug --profile=full",
    "bench:compare": "tsx bench/index.ts compare",
    "bench:baseline:update": "tsx bench/index.ts --baseline-update"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "preact",
    "signals",
    "rpc",
    "reflection",
    "reactive",
    "realtime",
    "websocket"
  ],
  "author": "Jason Miller (https://jasonformat.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/developit/mixed-signals.git"
  },
  "packageManager": "pnpm@10.33.2",
  "peerDependencies": {
    "@preact/signals-core": ">=1.14.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@changesets/cli": "^2.29.8",
    "@preact/signals-core": "^1.14.0",
    "hdr-histogram-js": "^3.0.1",
    "jsvu": "^3.0.3",
    "mitata": "^1.0.34",
    "rollup": "^4.52.4",
    "@rollup/plugin-commonjs": "^28.0.8",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-sucrase": "^5.0.2",
    "tinybench": "^5.1.0",
    "tslib": "^2.8.1",
    "tsdown": "^0.20.0",
    "tsx": "^4.20.6",
    "typedoc": "^0.28.13",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  }
}
