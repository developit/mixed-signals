{
  "name": "mixed-signals",
  "version": "0.2.1",
  "description": "RPC Reflection for Preact Models & Signals: use Models/Signals from a somewhere else (server/worker/etc) as if they were here.",
  "type": "module",
  "exports": {
    "./server": {
      "types": "./build/server.d.ts",
      "default": "./build/server.js"
    },
    "./client": {
      "types": "./build/client.d.ts",
      "default": "./build/client.js"
    },
    "./disposable.d.ts": "./disposable.d.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "build",
    "server",
    "client",
    "shared"
  ],
  "scripts": {
    "test": "vitest",
    "build": "tsdown",
    "typecheck": "tsc",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "docs:api": "node scripts/generate-readme.mjs",
    "prepublishOnly": "tsdown && node scripts/generate-readme.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "preact",
    "signals",
    "rpc",
    "reflection",
    "reactive",
    "realtime",
    "websocket"
  ],
  "author": "Jason Miller (https://jasonformat.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/developit/mixed-signals.git"
  },
  "peerDependencies": {
    "@preact/signals-core": ">=1.14.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@changesets/cli": "^2.29.8",
    "@preact/signals-core": "^1.14.0",
    "tsdown": "^0.20.0",
    "typedoc": "^0.28.13",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  }
}
