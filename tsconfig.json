{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2022", "DOM"]
  },
  "include": [
    "shared/**/*",
    "server/**/*",
    "client/**/*",
    "test/**/*",
    "demos/**/*"
  ]
}
